package host:interfaces@1.0.0;

interface kv-store {
  get: func(map: string, key: list<u8>) -> result<option<list<u8>>, string>;
  set: func(map: string, key: list<u8>, value: list<u8>) -> result<_, string>;
  list-keys: func(map: string) -> result<list<string>, string>;
  delete: func(map: string, key: list<u8>) -> result<_, string>;
}
