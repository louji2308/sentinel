package z:sentinel-compliance@1.0.0;

world sentinel-compliance {
  import host:tenant/tenant-context@1.0.0;
  import host:interfaces/logging@1.0.0;
  import host:interfaces/kv-store@1.0.0;
  import host:interfaces/signing@1.0.0;
  import host:interfaces/time@1.0.0;

  export contracts;
}

interface contracts {
  record generic-input {
    input:        option<list<u8>>,
    user-profile: option<list<u8>>,
    context:      option<list<u8>>,
  }

  evaluate-compliance: func(req: generic-input) -> result<list<u8>, string>;
  revoke-agent:        func(req: generic-input) -> result<list<u8>, string>;
  verify-receipt:      func(req: generic-input) -> result<list<u8>, string>;
  query-audit-log:     func(req: generic-input) -> result<list<u8>, string>;
  register-agent:      func(req: generic-input) -> result<list<u8>, string>;
  seed-policy:         func(req: generic-input) -> result<list<u8>, string>;
  resolve-escalation:  func(req: generic-input) -> result<list<u8>, string>;
}
