{
  "name": "sentinel",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/policy-engine",
    "packages/t3-client",
    "packages/oracle-server",
    "packages/agents",
    "packages/dashboard"
  ],
  "scripts": {
    "setup": "npx tsx scripts/setup.ts",
    "oracle": "npx tsx packages/oracle-server/src/index.ts",
    "dashboard": "cd packages/dashboard && npm run dev",
    "demo": "npx tsx scripts/05-run-demo.ts",
    "dev": "concurrently \"npm run oracle\" \"npm run dashboard\"",
    "gen:keys": "npx tsx scripts/generate-agent-keys.ts"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "dotenv": "^16.4.5"
  }
}