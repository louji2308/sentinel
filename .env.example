# ── Terminal 3 ──────────────────────────────────────────────────────────────
T3N_API_KEY=0x<your-private-key-here>
T3N_ENVIRONMENT=testnet
T3N_BASE_URL=https://cn-api.sg.testnet.t3n.terminal3.io

# ── Agent Keys ──────────────────────────────────────────────────────────────
# Generate with: npm run gen:keys
TRAVEL_AGENT_KEY=0x<generated-travel-agent-key>
HR_PAYROLL_AGENT_KEY=0x<generated-hr-payroll-agent-key>
ROGUE_AGENT_KEY=0x<generated-rogue-agent-key>

# ── Tenant Identity ─────────────────────────────────────────────────────────
# Set after running: npm run setup
SENTINEL_TENANT_DID=did:t3n:<your-tenant-did>
CONTRACT_TAIL=sentinel-compliance-oracle
CONTRACT_VERSION=1.0.0

# ── Operator Key ────────────────────────────────────────────────────────────
# Used to sign admin operations (register-agent, revoke-agent, seed-policy, 
# resolve-escalation). Must match the public key stored in the contract's 
# admin-config KV namespace under "operator-public-key".
# If not set, defaults to T3N_API_KEY.
OPERATOR_PRIVATE_KEY=0x<operator-private-key>

# ── Sentinel Oracle ─────────────────────────────────────────────────────────
ORACLE_PORT=3001
ORACLE_SECRET=<generate-a-random-secret>
SENTINEL_DB_DIR=./data
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=debug

# ── Dashboard ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_ORACLE_URL=http://localhost:3001
NEXT_PUBLIC_T3N_ENVIRONMENT=testnet
DASHBOARD_PORT=3000

# ── Webhooks (optional) ────────────────────────────────────────────────────
ESCALATE_WEBHOOK_URL=
ESCALATE_WEBHOOK_SECRET=

# ── Claude API (not used in compliance path) ───────────────────────────────
ANTHROPIC_API_KEY=
